# Database URL (SQLite is default, swap for Supabase PostgreSQL in production)
DATABASE_URL="file:./prisma/dev.db"

# -------------------------------------------------------------
# Google Cloud Workspace API Configuration (Libertydispatch.xyz)
# -------------------------------------------------------------
# Obtain these from Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-google-client-secret"

# A persistent refresh token authorized with scopes: 
# - https://www.googleapis.com/auth/gmail.modify (to read and send emails to Google Voice txt.voice addresses)
# - https://www.googleapis.com/auth/spreadsheets (to sync drivers to Google Sheets)
GOOGLE_REFRESH_TOKEN="1//0_your-long-lived-refresh-token"

# The Spreadsheet ID for driver CRM sync (found in your Google Sheet URL)
# Example: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEET_ID="1T8rQ_S9U02Dk-X7y_p4zYxX474Y0q1m3oK0qW1-RealID"

# -------------------------------------------------------------
# Twilio click-to-call dialer configuration
# -------------------------------------------------------------
# Obtain these from your Twilio Console (https://console.twilio.com)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"

# Your purchased Twilio phone number (must be in E.164 format, e.g. +14105550100)
TWILIO_PHONE_NUMBER="+14105550100"

# The dispatcher cell/office phone number to call first when bridging a call
# This is your personal phone that will ring when you click "Call Candidate"
DISPATCHER_PHONE_NUMBER="+14106354001"
