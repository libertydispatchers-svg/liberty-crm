generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  createdAt   DateTime     @default(now())
  crates      Crate[]
  generations Generation[]
  playlists   Playlist[]
}

model Generation {
  id         String   @id @default(cuid())
  prompt     String
  title      String?
  vibe       String?
  bpm        Int?
  key        String?
  beatUrl    String?
  stemStatus String   @default("none")
  status     String   @default("pending")
  taskId     String?
  userId     String?
  crateId    String?
  createdAt  DateTime @default(now())
  crate      Crate?   @relation(fields: [crateId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
}

model Crate {
  id          String       @id @default(cuid())
  name        String
  userId      String?
  createdAt   DateTime     @default(now())
  user        User?        @relation(fields: [userId], references: [id])
  generations Generation[]
}

model Playlist {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Applicant {
  id           String     @id @default(cuid())
  name         String
  phone        String
  email        String
  status       String     @default("NEW")
  source       String     @default("EMAIL")
  availability String     @default("{}")
  passwordHash String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  documents    Document[]
  notes        Note[]
  jobs         Job[]
}

model Note {
  id          String    @id @default(cuid())
  content     String
  createdAt   DateTime  @default(now())
  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
}

model Document {
  id          String    @id @default(cuid())
  name        String
  status      String    @default("NOT_SENT")
  sentAt      DateTime?
  signedAt    DateTime?
  fileUrl     String?
  esignData   String?
  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Job {
  id               String     @id @default(cuid())
  title            String
  company          String
  pickupAddress    String
  dropoffAddress   String
  payout           String
  status           String     @default("OPEN")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  assignedDriverId String?
  assignedDriver   Applicant? @relation(fields: [assignedDriverId], references: [id], onDelete: SetNull)
}

model Vendor {
  id           String     @id @default(cuid())
  businessName String
  contactName  String
  phone        String
  whatsapp     String?
  email        String
  businessType String     @default("OTHER")
  status       String     @default("NEW")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}
